{
  "expo": {
    "name": "PHRIT",
    "slug": "phrit",
    "version": "1.0.0",
    "scheme": "phrit",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#F7F4EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phrit.app"
    },
    "android": {
      "package": "com.phrit.app",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F4EE"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "PHRIT uses photo access so you can share today's image."
        }
      ],
      "expo-asset"
    ],
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
